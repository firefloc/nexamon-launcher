{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexamon Launcher",
  "version": "1.0.1",
  "identifier": "com.nexamon.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nexamon Launcher",
        "width": 1000,
        "height": 650,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/firefloc/nexamon-launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCNTM2NUZBODMwRjUxQzUKUldURlVRK0QrbVZUeTVJSy81TEVtTlpTRnFMcmJ5MWVPaFJqN3pMb1E3L2l6NHU5ZU9lYk9idmUK"
    }
  }
}
